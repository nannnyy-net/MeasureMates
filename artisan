<?php

$projectRoot = __DIR__ . '/MeasureMate';

if (!is_dir($projectRoot)) {
    fwrite(STDERR, "Laravel project directory not found: {$projectRoot}\n");
    exit(1);
}

chdir($projectRoot);

$script = $projectRoot . '/artisan';

if (!is_file($script)) {
    fwrite(STDERR, "Laravel entrypoint not found: {$script}\n");
    exit(1);
}

$_SERVER['argv'] = array_merge([realpath($script)], array_slice($_SERVER['argv'], 1));
$_SERVER['argc'] = count($_SERVER['argv']);

require $script;
